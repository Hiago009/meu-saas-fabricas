generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" 
  url      = env("DATABASE_URL")
}

model Empresa {
  id             Int      @id @default(autoincrement())
  nomeFantasia   String   
  dono           String   
  telefone       String?
  emailLogin     String   @unique 
  senhaLogin     String   
  status         String   @default("TESTE") 
  dataExpiracao  DateTime 
  criadoEm       DateTime @default(now())

  produtos       Produto[]
  sacoleiros     Sacoleiro[]
  malas          Mala[]
  vendas         VendaSacoleiro[]
}

model Produto {
  id          Int      @id @default(autoincrement())
  empresaId   Int      
  empresa     Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  
  codigo      String?
  produto     String
  
  // 👇 AS NOSSAS 3 GAVETAS DE PREÇO
  precoCusto  Float?   @default(0) 
  preco       Float    
  precoVarejo Float?   @default(0) 
  
  quantidade  Int
  criadoEm    DateTime @default(now())
}

model Sacoleiro {
  id           Int      @id @default(autoincrement())
  empresaId    Int      
  empresa      Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  
  nome         String
  telefone     String?
  usuarioApp   String?  @unique
  senhaApp     String?
  ultimaCompra DateTime?
  criadoEm     DateTime @default(now())
  
  malas        Mala[]
  vendas       VendaSacoleiro[]
  vendedoras   VendedoraFinal[] 
  repasses     RepasseVendedora[]
}

model Mala {
  id             Int      @id @default(autoincrement())
  empresaId      Int      
  empresa        Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  sacoleiroId    Int
  sacoleiro      Sacoleiro @relation(fields: [sacoleiroId], references: [id], onDelete: Cascade)
  
  produtoNome    String   
  total          Float
  status         String   @default("PENDENTE")
  dataVencimento DateTime?
  assinatura     String?  
  criadoEm       DateTime @default(now())
}

model VendaSacoleiro {
  id             Int      @id @default(autoincrement())
  empresaId      Int      
  empresa        Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  sacoleiroId    Int
  sacoleiro      Sacoleiro @relation(fields: [sacoleiroId], references: [id], onDelete: Cascade)
  
  nomeVendedora  String
  valor          Float
  dataVencimento DateTime
  assinatura     String?
  status         String   @default("PENDENTE")
  criadoEm       DateTime @default(now())
}

model VendedoraFinal {
  id          Int      @id @default(autoincrement())
  nome        String
  telefone    String   
  endereco    String   
  praca       String?  @default("Geral")
  diaCobranca String?  
  
  sacoleiraId Int
  sacoleira   Sacoleiro  @relation(fields: [sacoleiraId], references: [id]) 

  kitsPegos   RepasseVendedora[] 

  criadoEm    DateTime @default(now())
}

model RepasseVendedora {
  id              Int      @id @default(autoincrement())
  descricaoKits   String   
  valorTotal      Float    
  status          String   @default("NA_RUA") 
  dataCobranca    String?  
  
  sacoleiroId     Int
  sacoleiro       Sacoleiro @relation(fields: [sacoleiroId], references: [id])
  
  vendedoraId     Int
  vendedora       VendedoraFinal @relation(fields: [vendedoraId], references: [id])

  criadoEm        DateTime @default(now())
}
